{
  "expo": {
    "name": "ScanIt",
    "slug": "scanit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scanit",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "ScanIt needs camera access to scan and identify products.",
        "NSPhotoLibraryUsageDescription": "ScanIt needs photo library access to pick product images.",
        "NSLocationWhenInUseUsageDescription": "ScanIt uses your location to find nearby sellers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E76F2E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E76F2E",
          "dark": {
            "backgroundColor": "#E76F2E"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "ScanIt needs camera access to scan and identify products."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ScanIt needs photo library access to pick product images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
